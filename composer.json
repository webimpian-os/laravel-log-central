{
    "name": "webimpian/laravel-log-central",
    "description": "Ship logs and exceptions from a Laravel app to a Log Central server.",
    "keywords": ["laravel", "logging", "error-tracking", "log-central"],
    "license": "MIT",
    "authors": [
        {
            "name": "Khairul Imran",
            "email": "infrastructure@webimpian.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Webimpian\\LogCentral\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webimpian\\LogCentral\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webimpian\\LogCentral\\LogCentralServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
